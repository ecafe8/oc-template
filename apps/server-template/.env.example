# Server
NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/oc_api_db

# Auth
AUTH_SERVICE_URL=http://localhost:4999
INTERNAL_API_SECRET=your-shared-internal-api-secret-minimum-32-characters

# CORS (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3399

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# OSS
OSS_BUCKET=your-oss-bucket
OSS_REGION=cn-hangzhou
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_STS_ROLE_ARN=acs:ram::1234567890123456:role/your-oss-role
OSS_UPLOAD_DIR_PREFIX=your-project-name/attachments
OSS_STS_SESSION_NAME=server-template
OSS_STS_EXPIRES_IN_SECONDS=3600
OSS_SIGNATURE_EXPIRES_IN_SECONDS=600
