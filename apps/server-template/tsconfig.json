{
  "extends": "@repo/typescript-config/hono.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "lib": ["ESNext"],
    "paths": {
      "@repo/share-auth": ["../../packages/share-auth/src/index.ts"],
      "@repo/share-auth/*": ["../../packages/share-auth/src/*"],
      "@repo/server-template/*": ["./src/*"],
      "@repo/share-backend/*": ["../../packages/share-backend/src/*"]
    },
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": [
    "src/**/*.ts",
    "exports/**/*.ts",
    "scripts/**/*.ts",
    "drizzle.config.ts",
    "../../packages/share-auth/src/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
