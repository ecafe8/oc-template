NODE_ENV=development

DATABASE_URL=

# BetterAuth 密钥 - 使用 `openssl rand -base64 32` 生成一个安全的密钥
BETTER_AUTH_SECRET=""
# BetterAuth API 的 URL，默认为本地开发环境的地址
BETTER_AUTH_URL=http://localhost:4999
# 前端用于调用 BetterAuth API 的 URL，通常与 BETTER_AUTH_URL 相同
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:4999
BETTER_AUTH_TELEMETRY=0
# 受信任的来源列表，允许来自这些来源的请求访问 BetterAuth API
# 使用逗号分隔多个来源，支持 * 通配符匹配主机名（不含协议前缀时仅匹配 host 部分）
# 例如：localhost:* 匹配 localhost:3000 / localhost:3333 等所有本地端口
# 生产环境示例：BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com,https://www.example.com
BETTER_AUTH_TRUSTED_ORIGINS=localhost:*
# BETTER_AUTH_CROSS_SUBDOMAIN 仅在需要跨子域共享登录态时设置
# 开发环境建议使用 auth.local.com / app.local.com 这一类域名再开启
BETTER_AUTH_CROSS_SUBDOMAIN=
# 用于组织邀请的密钥 - 使用 `openssl rand -base64 32` 生成一个安全的密钥
BETTER_AUTH_ORGANIZATION_INVITE_SECRET=""

# 内部服务间通信密钥 - 用于保护 /api/internal/* 端点
# 使用 `openssl rand -base64 32` 生成，并在所有调用方（如 server-counselor）保持一致
INTERNAL_API_SECRET=""

# 可选：启用 Google OAuth 后再填写
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
