{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@repo/server-template/rpc": ["../server-template/exports/rpc.ts"],
      "@repo/share-ui/*": ["../../packages/share-ui/src/*"],
      "@repo/web-template/*": ["./*"]
