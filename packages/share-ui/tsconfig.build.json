{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-types",
    "rootDir": ".",
    "tsBuildInfoFile": "./dist-types/.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "postcss.config.mjs"],
  "exclude": ["dist", "dist-types", "build", "node_modules"]
}
