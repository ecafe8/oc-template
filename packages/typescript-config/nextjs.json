{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "customConditions": ["module"],
    "jsx": "preserve",
    "noEmit": true,
    "lib": [
      "ES2024",
      "DOM",
      "DOM.Iterable"
    ],
    "types": []
  }
}
