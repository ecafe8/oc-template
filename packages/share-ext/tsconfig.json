{
  "extends": "@repo/typescript-config/browser-extension.json",
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@repo/share-ext": ["./index.ts"],
      "@repo/share-ext/*": ["./src/*"]
    }
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "build", "node_modules"]
}
